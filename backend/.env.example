# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# RapidAPI key (used for Booking.com hotel search)
# Get yours at: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# AviationStack (flight status — optional, mock data used if missing)
AVIATIONSTACK_KEY=your_aviationstack_key_here

# Google Gemini (AI chat — optional, rule-based fallback used if missing)
GEMINI_KEY=your_gemini_key_here
